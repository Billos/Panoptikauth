# Server configuration
PORT=3000
LOCALE=fr-FR
TZ=Europe/Paris

# WUD (What's Up Docker) integration
WUD_URL=http://wud:3000
WUD_POLL_INTERVAL=300
WUD_GOTIFY_APP_NAME=wud

# Gotify client token (required for WUD poller to delete resolved notifications)
GOTIFY_URL=http://gotify:80
GOTIFY_CLIENT_TOKEN=